rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /clothes/{uid}/{fileName} {
      allow read, write: if isOwner(uid);
    }

    // Full-body photo + cached photoreal try-on results, owner-only.
    match /tryon/{uid}/{allPaths=**} {
      allow read, write: if isOwner(uid);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
