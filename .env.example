# Firebase web config — copy this file to .env.local and fill in your project's
# values from Firebase Console → Project settings → Your apps → SDK setup.
# If left unset, the app falls back to the values in src/firebase.js.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: local CatVTON try-on server for photoreal "See it on me".
# See tryon-server/README.md. Defaults to http://localhost:7860 if unset.
VITE_TRYON_SERVER_URL=http://localhost:7860
