# Firebase web config — copy this file to .env.local and fill in your project's
# values from Firebase Console → Project settings → Your apps → SDK setup.
# If left unset, the app falls back to the values in src/firebase.js.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
